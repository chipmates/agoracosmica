---
import { getT } from '../i18n';
import type { Lang } from '../i18n';
import { publicUrl } from '../lib/urls';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getT(lang);

// Per-language podcast shows (mirrors ContactContent.astro). The footer renders
// on every page, so DE pages must link the German show, not the English one.
const spotifyUrl = lang === 'de'
  ? 'https://open.spotify.com/show/5i63mEKJuCVniSIViXbEP8'
  : 'https://open.spotify.com/show/3V02q5c8NAnFD1W2kQBYzd';
const applePodcastUrl = lang === 'de'
  ? 'https://podcasts.apple.com/us/podcast/agora-cosmica-deutsch/id1871505945'
  : 'https://podcasts.apple.com/us/podcast/agora-cosmica/id1871505788';
---
<footer class="pub-footer">
  <div class="pub-footer__inner">
    <div class="pub-footer__brand">
      <span class="pub-footer__name">Agora Cosmica</span>
      <p class="pub-footer__tagline">{t('footer.tagline')}</p>
    </div>

    <div class="pub-footer__links">
      <div class="pub-footer__col">
        <a href={publicUrl(lang, '/figures')}>{t('nav.figures')}</a>
        <a href={publicUrl(lang, '/themes')}>{t('nav.themes')}</a>
        <a href={publicUrl(lang, '/about')}>{t('nav.about')}</a>
        <a href={publicUrl(lang, '/echoes')}>{t('nav.whyEchoes')}</a>
        <a href={lang === 'de' ? '/de/methodik/' : '/methodology/'}>{lang === 'de' ? 'Methodik' : 'Methodology'}</a>
        <a href={publicUrl(lang, '/open-source-philosophy-app')}>{lang === 'de' ? 'Open-Source-App' : 'Open source app'}</a>
        <a href={publicUrl(lang, '/contact')}>{t('nav.contact')}</a>
      </div>
      <div class="pub-footer__col">
        <a href="/impressum/">{t('footer.impressum')}</a>
        <a href={lang === 'en' ? '/privacy/' : '/datenschutz/'}>{t('footer.datenschutz')}</a>
        <a href="/cookie-policy/">{t('footer.cookiePolicy')}</a>
        <a href="/nutzungsbedingungen/">{t('footer.terms')}</a>
      </div>
      <div class="pub-footer__col">
        <a href={spotifyUrl} target="_blank" rel="noopener noreferrer">Spotify</a>
        <a href={applePodcastUrl} target="_blank" rel="noopener noreferrer">Apple Podcasts</a>
        <a href="https://github.com/chipmates/agoracosmica" target="_blank" rel="noopener noreferrer">GitHub</a>
      </div>
    </div>

    <div class="pub-footer__bottom">
      <p class="pub-footer__project">{t('footer.projectOf')}</p>
      <p class="pub-footer__trust">{t('footer.trustSignals')}</p>
      <p class="pub-footer__star">
        <a href="https://github.com/chipmates/agoracosmica" target="_blank" rel="noopener noreferrer">{t('footer.starCta')}</a>
      </p>
    </div>
  </div>
</footer>

<style>
  /* Subtle, site-wide star ask. Scoped to the footer so it does not touch the
     frozen global CSS. Plain repo link, no third-party star widget. */
  .pub-footer__star {
    margin-top: 0.75rem;
    font-size: 0.85rem;
  }
  .pub-footer__star a {
    color: var(--gold-primary, #E6BC5C);
    text-decoration: none;
  }
  .pub-footer__star a:hover,
  .pub-footer__star a:focus-visible {
    color: var(--gold-hover, #F6D55C);
    text-decoration: underline;
  }
</style>
