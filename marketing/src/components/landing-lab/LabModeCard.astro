---
// Homepage body partial: one "way to learn from a mind" mode card.
// The mode name is a small heading, the body is the one-sentence mode
// description. No copy is introduced here, HomepageBody passes the text in.
// An optional step label (Chapter 1..4) marks the four arc modes; the two
// go-further modes (Free Talk, Cosmic Council) carry no step.
interface Props {
  name: string;
  text: string;
  step?: string;
}
const { name, text, step } = Astro.props;
---
<div class="ll2-mode-card">
  {step && <p class="ll2-mode-card__step">{step}</p>}
  <h3 class="ll2-mode-card__name">{name}</h3>
  <p class="ll2-mode-card__text">{text}</p>
</div>
