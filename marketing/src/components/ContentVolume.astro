---
import { getT } from '../i18n';
import type { Lang } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getT(lang);
---
<div class="pub-volume">
  <span class="pub-volume__item">360 {t('volume.stories')}</span>
  <span class="pub-volume__sep">·</span>
  <span class="pub-volume__item">360 {t('volume.teachings')}</span>
  <span class="pub-volume__sep">·</span>
  <span class="pub-volume__item">110 {t('volume.debates')}</span>
</div>
