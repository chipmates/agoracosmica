---
// Sticky top navbar for all marketing pages. Static HTML — no React needed.
// The "Start Exploring" CTA is a plain <a href="/app"> that does a hard nav
// into the React SPA. The conversion + entry-intent fire from a tiny global click
// handler set up in Public.astro (vanilla JS, no React island for this).

import { getT } from '../i18n';
import type { Lang } from '../i18n';
import { publicUrl, stripLangPrefix } from '../lib/urls';

interface Props {
  lang: Lang;
  currentPath: string;
}

const { lang, currentPath } = Astro.props;
const t = getT(lang);

const basePath = stripLangPrefix(currentPath);
const otherLang: Lang = lang === 'de' ? 'en' : 'de';
const langSwitchUrl = otherLang === 'de' ? `/de${basePath}` : basePath;

const navLinks = [
  { to: publicUrl(lang, '/figures'), label: t('nav.figures') },
  { to: publicUrl(lang, '/themes'), label: t('nav.themes') },
  { to: publicUrl(lang, '/about'), label: t('nav.about') },
  { to: publicUrl(lang, '/contact'), label: t('nav.contact') },
];

const isActive = (path: string) => currentPath === path || currentPath === path.replace(/\/$/, '');
---
<header class="pub-navbar liquid-glass--sidebar">
  <div class="pub-navbar__inner">
    <a href={publicUrl(lang, '/')} class="pub-navbar__logo">
      <svg class="pub-navbar__logo-mark" viewBox="0 0 200 200" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <radialGradient id="navLogoDot" cx="50%" cy="50%" r="50%">
            <stop offset="0%" stop-color="var(--gold-light, #f8e696)" />
            <stop offset="40%" stop-color="var(--gold-subtle, #e6bc5c)" />
            <stop offset="100%" stop-color="var(--gold-deep, #be9b37)" />
          </radialGradient>
        </defs>
        <circle cx="100" cy="100" r="76" fill="none" stroke="var(--gold-subtle, #e6bc5c)" stroke-width="3.5" />
        <circle cx="100" cy="100" r="31" fill="url(#navLogoDot)" />
      </svg>
      <span class="pub-navbar__logo-text">
        <span class="pub-navbar__logo-name">Agora Cosmica</span>
        <span class="pub-navbar__logo-tagline">{t('footer.tagline')}</span>
      </span>
    </a>

    <nav class="pub-navbar__nav" id="pub-nav" aria-label="Main navigation">
      {navLinks.map(link => (
        <a
          href={link.to}
          class={`pub-navbar__link ${isActive(link.to) ? 'pub-navbar__link--active' : ''}`}
        >
          {link.label}
        </a>
      ))}

      <a
        href={langSwitchUrl}
        class="pub-navbar__lang"
        aria-label={otherLang === 'de' ? 'DE: Deutsche Version' : 'EN: English version'}
      >
        {otherLang.toUpperCase()}
      </a>

      <a href="/app" class="pub-navbar__cta" data-agc-cta="start-exploring">
        {t('nav.startExploring')}
      </a>
    </nav>

    <button
      class="pub-navbar__burger"
      aria-expanded="false"
      aria-controls="pub-nav"
      aria-label={t('nav.menu')}
      data-agc-burger
    >
      <span class="pub-navbar__burger-line" />
      <span class="pub-navbar__burger-line" />
      <span class="pub-navbar__burger-line" />
    </button>
  </div>
</header>

<style is:global>
  /* Bug fix: .pub-navbar had no background in public-layout.css, so the
     sticky bar showed through to page content on scroll. Same cosmic blue
     + blur as .pub-cta--sticky for visual consistency. */
  .pub-navbar {
    background: color-mix(in srgb, var(--bg-deep-space, #0C1133) 92%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid color-mix(in srgb, var(--gold-primary) 16%, transparent);
  }

  /* Brand lockup: the CosmicLogo eclipse mark from the login page sits beside
     the wordmark. Class-stacked (0,2,0) so it beats public-layout.css's
     .pub-navbar__logo (0,1,0) regardless of bundle order, switching the lockup
     from a column to an icon + text row. */
  .pub-navbar .pub-navbar__logo {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 0.6rem;
  }
  .pub-navbar__logo-mark {
    width: 30px;
    height: 30px;
    flex: 0 0 auto;
  }
  .pub-navbar__logo-text {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
  }

  /* Background fix for the open mobile menu. public-layout.css sets
     .pub-navbar__nav { background: var(--bg-primary, #151C47) } inside
     its mobile media query, and that rule lands AFTER this Astro
     <style is:global> in the bundled CSS. A plain .pub-navbar__nav--open
     selector ties on specificity (0,1,0) and loses on source order,
     leaving the panel painted with whatever var(--bg-primary) resolves
     to in the marketing-page context (which on iOS Safari rendered
     effectively transparent). Stack the class selectors so this rule
     hits specificity 0,3,0 and wins regardless of bundle order, with
     a solid #0C1133 declaration before the color-mix line so the
     panel still has a real background if color-mix is unsupported or
     the declaration is parsed as invalid. Lighter blur(10) on mobile
     so older phones don't fight a heavy filter. */
  @media (max-width: 640px) {
    .pub-navbar,
    .pub-cta--sticky {
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
    }

    .pub-navbar .pub-navbar__nav.pub-navbar__nav--open {
      /* The navbar runs backdrop-filter (via .liquid-glass--sidebar
         and the inline rule above), and a non-none backdrop-filter
         makes the element a containing block for descendant
         position:fixed children. The menu's inset: 64px 0 0 from
         public-layout.css then resolved relative to the 64px-tall
         navbar instead of the viewport, collapsing the panel to 0
         height. Items overflowed downward with overflow:visible and
         rendered scattered across the page with the page background
         showing through between them. Pin the menu to the viewport
         with explicit top + height so its size no longer depends on
         the containing block. dvh handles iOS browser-chrome
         retraction; vh is the fallback for older Safari. */
      top: 64px;
      right: 0;
      left: 0;
      bottom: auto;
      height: calc(100vh - 64px);
      height: calc(100dvh - 64px);

      background: #0C1133;
      background: color-mix(in srgb, var(--bg-deep-space, #0C1133) 90%, transparent);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      border-top: 1px solid color-mix(in srgb, var(--gold-primary, #E6BC5C) 16%, transparent);
      box-shadow: 0 16px 40px color-mix(in srgb, #000 45%, transparent);
      padding-bottom: max(2rem, env(safe-area-inset-bottom));
    }

    /* Hamburger morphs into a close icon when the panel is open. */
    .pub-navbar__burger-line {
      transform-origin: center;
      transition: transform 0.2s ease, opacity 0.16s ease;
    }
    .pub-navbar__burger[aria-expanded="true"] .pub-navbar__burger-line:nth-child(1) {
      transform: translateY(7px) rotate(45deg);
    }
    .pub-navbar__burger[aria-expanded="true"] .pub-navbar__burger-line:nth-child(2) {
      opacity: 0;
    }
    .pub-navbar__burger[aria-expanded="true"] .pub-navbar__burger-line:nth-child(3) {
      transform: translateY(-7px) rotate(-45deg);
    }
  }
</style>
