---
// Sticky top navbar for all marketing pages. Static HTML — no React needed.
// The "Start Exploring" CTA is a plain <a href="/"> that does a hard nav into
// the React SPA. The conversion + entry-intent fire from a tiny global click
// handler set up in Public.astro (vanilla JS, no React island for this).

import { getT } from '../i18n';
import type { Lang } from '../i18n';
import { publicUrl, stripLangPrefix } from '../lib/urls';

interface Props {
  lang: Lang;
  currentPath: string;
}

const { lang, currentPath } = Astro.props;
const t = getT(lang);

const basePath = stripLangPrefix(currentPath);
const otherLang: Lang = lang === 'de' ? 'en' : 'de';
const langSwitchUrl = otherLang === 'de' ? `/de${basePath}` : basePath;

const navLinks = [
  { to: publicUrl(lang, '/figures'), label: t('nav.figures') },
  { to: publicUrl(lang, '/themes'), label: t('nav.themes') },
  { to: publicUrl(lang, '/about'), label: t('nav.about') },
  { to: publicUrl(lang, '/contact'), label: t('nav.contact') },
];

const isActive = (path: string) => currentPath === path || currentPath === path.replace(/\/$/, '');
---
<header class="pub-navbar liquid-glass--sidebar">
  <div class="pub-navbar__inner">
    <a href={publicUrl(lang, '/figures')} class="pub-navbar__logo">
      <span class="pub-navbar__logo-name">Agora Cosmica</span>
      <span class="pub-navbar__logo-tagline">{t('footer.tagline')}</span>
    </a>

    <nav class="pub-navbar__nav" aria-label="Main navigation">
      {navLinks.map(link => (
        <a
          href={link.to}
          class={`pub-navbar__link ${isActive(link.to) ? 'pub-navbar__link--active' : ''}`}
        >
          {link.label}
        </a>
      ))}

      <a
        href={langSwitchUrl}
        class="pub-navbar__lang"
        aria-label={`Switch to ${otherLang === 'de' ? 'German' : 'English'}`}
      >
        {otherLang.toUpperCase()}
      </a>

      <a href="/" class="pub-navbar__cta" data-agc-cta="start-exploring">
        {t('nav.startExploring')}
      </a>
    </nav>

    <button
      class="pub-navbar__burger"
      aria-expanded="false"
      aria-label={t('nav.menu')}
      data-agc-burger
    >
      <span class="pub-navbar__burger-line" />
      <span class="pub-navbar__burger-line" />
      <span class="pub-navbar__burger-line" />
    </button>
  </div>
</header>
