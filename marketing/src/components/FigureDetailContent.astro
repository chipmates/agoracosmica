---
// Full body for a figure detail page. Static Astro everywhere except the
// trailer button (React island, inside FigureHero). All data resolves at
// build time from the existing client/ data files via the @client alias.

import Breadcrumbs from './Breadcrumbs.astro';
import FigureHero from './FigureHero.astro';
import EchoNote from './EchoNote.astro';
import JourneyOverview from './JourneyOverview.astro';
import FigureQA from './FigureQA.astro';
import CollapsibleSection from './CollapsibleSection.astro';
import CouncilPreview from './CouncilPreview.astro';
import StaticImage from './StaticImage.astro';
import PublicCTA from './PublicCTA.astro';
import SourcesBlock from './SourcesBlock.astro';

import { getT } from '../i18n';
import type { Lang } from '../i18n';
import { publicUrl } from '../lib/urls';
import { getSeedsFor } from '../lib/seeds';
import { getFigureById } from '@client/data/public/figuresCatalog';
import { figureSlugToId, figureIdToSlug } from '@client/data/public/slugMap';
import { figureThemes } from '@client/data/public/figureSeo';
import { councilCatalog, getShortDisplayName } from '@client/data/councilCatalog';
import { dickinsonPoemsFaqEn, dickinsonPoemsFaqDe } from '../lib/dickinsonPoemsFaq';

interface Props {
  figureId: string;
  slug: string;
  lang: Lang;
}

const { figureId, slug, lang } = Astro.props;
const t = getT(lang);
const figure = getFigureById(figureId, lang);

if (!figure) {
  throw new Error(`Unknown figure: ${figureId}`);
}

const seeds = getSeedsFor(figureId, lang);
const shortName = getShortDisplayName(figureId);

// Councils where this figure participates (moderator or panelist).
const relatedCouncils = councilCatalog.filter(c =>
  c.moderator.id === figureId ||
  c.participants.some(p => p.id === figureId),
);

// Related figures drawn from seed connections, ranked by how often this figure
// references them across seeds (a stronger relevance signal than first-seen
// order), then the top 8. Internal linking is the one lever a zero-authority
// domain fully owns, so pass PageRank to as many real connections as fit.
const connectionCounts = new Map<string, number>();
for (const seed of seeds) {
  for (const conn of seed.connections ?? []) {
    if (conn.figure !== figureId && figureIdToSlug[conn.figure]) {
      connectionCounts.set(conn.figure, (connectionCounts.get(conn.figure) ?? 0) + 1);
    }
  }
}
const relatedFigureIds = [...connectionCounts.entries()]
  .sort((a, b) => b[1] - a[1])
  .map(([id]) => id)
  .slice(0, 8);
const themesForFigure = figureThemes[figureId] ?? [];

// Figures whose Ideas list opens by default: the demand figures, where the
// extra crawlable, above-the-fold body text matters most for AI extraction.
const OPEN_IDEAS = new Set(['campbell', 'dickinson', 'jung', 'gautama', 'aurelius']);

// Governing-hub up-link (the "up" half of the hub<->figure symbiosis): the 13
// philosophy-cluster figures point to the philosophy hub, every other figure to
// the wisdom hub. The DE hubs use localized slugs (philosophie-lernen, not a
// /de/ prefix of the EN slug), so the href is built literally per language.
const PHILO_FIGURES = new Set([
  'laozi', 'aurelius', 'plato', 'nietzsche', 'schopenhauer', 'beauvoir',
  'gautama', 'zenji', 'eckhart', 'bingen', 'rumi', 'jung', 'campbell',
]);
const isPhiloFigure = PHILO_FIGURES.has(figureId);
const hubHref = lang === 'de'
  ? (isPhiloFigure ? '/de/philosophie-lernen/' : '/de/von-historischen-persoenlichkeiten-lernen/')
  : (isPhiloFigure ? '/ai-philosophy-tutor/' : '/learn-from-historical-figures/');
const hubLinkLabel = isPhiloFigure
  ? (lang === 'de' ? 'Philosophie lernen mit einem KI-Tutor' : 'Learn philosophy with an AI tutor')
  : (lang === 'de' ? 'Von historischen Persönlichkeiten lernen' : 'Learn from historical figures');
const hubLinkLead = lang === 'de' ? 'Weiter erkunden: ' : 'Keep exploring: ';

// Dickinson-only interpretive capsule: "what are her poems about" (the winnable
// query) as a visible, snippet-eligible answer that funnels into her poems page.
// Same array drives the FAQPage JSON-LD in the route, so DOM and schema match.
const poemsFaq = figureId === 'dickinson' ? (lang === 'de' ? dickinsonPoemsFaqDe : dickinsonPoemsFaqEn) : null;
const poemsLinkLabel = lang === 'de'
  ? 'Lies ihre Gedichte nach Thema, in ihrer eigenen Handschrift →'
  : 'Read her poems grouped by theme, in her own hand →';

// Light cleanup for displayed prose: strip em/en dashes + stray semicolons.
function cleanDisplayText(s: string): string {
  return s
    .replace(/\s*[—–]\s*/g, ', ')
    .replace(/\s*;\s*/g, ', ')
    .replace(/,\s*,/g, ',')
    .trim();
}
---
<div class="pub-content pub-figure">
  <Breadcrumbs
    lang={lang}
    items={[
      { label: t('breadcrumbs.figures'), path: '/figures' },
      { label: figure.name },
    ]}
  />

  <FigureHero figure={figure} lang={lang} />

  {figure.essence && (
    <p class="pub-section__text pub-fig-essence">{cleanDisplayText(figure.essence)}</p>
  )}

  <EchoNote variant="figure" name={figure.name} lang={lang} />

  <p class="pub-section__text pub-figure__methodlink">
    <a class="pub-textlink" href={lang === 'de' ? '/de/methodik/' : '/methodology/'}>
      {lang === 'de' ? 'Wie wir diese Echos bauen und prüfen' : 'How we build and fact-check these Echoes'}
    </a>
  </p>

  <JourneyOverview figureId={figureId} figureName={figure.name} lang={lang} />

  <FigureQA figureId={figureId} lang={lang} />

  <!-- Desktop-only inline CTA. The sticky bar below is mobile-only
       (display:none on desktop), so without this a desktop visitor on a figure
       page had no figure-specific deep-link and fell back to the generic navbar
       CTA into the gallery. Carries the same /app?figure={slug} deep-link, and
       is hidden on mobile (the sticky bar covers it there) so each viewport
       shows exactly one figure CTA. -->
  <PublicCTA
    variant="inline"
    figureId={figureId}
    figureName={shortName}
    lang={lang}
    class="pub-cta--desktop"
  />

  {poemsFaq && (
    <section class="pub-section pub-figure__poems">
      <h2 class="pub-section__title">{poemsFaq[0].q}</h2>
      <p class="pub-section__text">{poemsFaq[0].a}</p>
      <p class="pub-section__text pub-figure__poems-link">
        <a class="pub-textlink" href="/figures/emily-dickinson/poems">{poemsLinkLabel}</a>
      </p>
      {poemsFaq.slice(1).map(item => (
        <div class="pub-figure__qa">
          <h3 class="pub-figure__qa-q">{item.q}</h3>
          <p class="pub-section__text">{item.a}</p>
        </div>
      ))}
    </section>
  )}

  {seeds.length > 0 && (
    <CollapsibleSection
      title={t('figures.ideasHeading')}
      count={seeds.length}
      defaultOpen={OPEN_IDEAS.has(figureId)}
    >
      <ol class="pub-ideas">
        {seeds.map((seed, i) => (
          <li class="pub-ideas__item" id={`idea-${i + 1}`}>
            <span class="pub-ideas__title">{seed.title}</span>
            {seed.summary && (
              <span class="pub-ideas__summary">{cleanDisplayText(seed.summary)}</span>
            )}
            {seed.coreInsights && seed.coreInsights.length > 0 && (
              <details class="pub-ideas__insights">
                <summary>{lang === 'de' ? 'Kerngedanken' : 'Core ideas'}</summary>
                <ul>
                  {seed.coreInsights.map(ci => (
                    <li>{cleanDisplayText(ci)}</li>
                  ))}
                </ul>
              </details>
            )}
          </li>
        ))}
      </ol>
    </CollapsibleSection>
  )}

  {figure.keyConcepts.length > 0 && (
    <CollapsibleSection title={t('figures.keyIdeas')}>
      <div class="pub-concepts">
        {figure.keyConcepts.map(concept => (
          <div class="pub-concept">
            <div class="pub-concept__term">{concept.term}</div>
            <div class="pub-concept__def">
              {cleanDisplayText(concept.definition)}
            </div>
          </div>
        ))}
      </div>
      {figure.primaryWorks.length > 0 && (
        <p class="pub-concept__works">
          <strong>{t('figures.primaryWorks')}:</strong>{' '}
          {figure.primaryWorks.map(cleanDisplayText).join(', ')}
        </p>
      )}
    </CollapsibleSection>
  )}

  {relatedCouncils.length > 0 && (
    <CollapsibleSection
      title={t('figures.councilAppearances')}
      count={relatedCouncils.length}
    >
      <div class="pub-council-list">
        {relatedCouncils.map(council => (
          <CouncilPreview council={council} lang={lang} />
        ))}
      </div>
    </CollapsibleSection>
  )}

  {themesForFigure.length > 0 && (
    <CollapsibleSection title={t('figures.themes')}>
      <div class="pub-grid pub-grid--3">
        {themesForFigure.map(themeId => (
          <a
            href={publicUrl(lang, `/themes/${themeId}`)}
            class="pub-theme-card"
          >
            <h3 class="pub-theme-card__name">{t(`themes.${themeId}.name`)}</h3>
            <p class="pub-theme-card__tagline">{t(`themes.${themeId}.tagline`)}</p>
          </a>
        ))}
      </div>
    </CollapsibleSection>
  )}

  <p class="pub-section__text pub-figure__hublink">
    {hubLinkLead}<a class="pub-textlink" href={hubHref}>{hubLinkLabel}</a>
  </p>

  {relatedFigureIds.length > 0 && (
    <CollapsibleSection
      title={t('figures.relatedFigures')}
      count={relatedFigureIds.length}
    >
      <div class="pub-grid pub-grid--2">
        {relatedFigureIds.map(relId => {
          const relFigure = getFigureById(relId, lang);
          const relSlug = figureIdToSlug[relId];
          if (!relFigure || !relSlug) return null;
          return (
            <a
              href={publicUrl(lang, `/figures/${relSlug}`)}
              class="pub-figure-card pub-figure-card--row"
            >
              <StaticImage
                figureId={relId}
                type="thumbnail"
                alt={relFigure.name}
                loading="lazy"
                width={64}
                height={64}
                sizes="64px"
              />
              <div>
                <div class="pub-figure-card__name">{relFigure.name}</div>
                <div class="pub-figure-card__tradition">{relFigure.tradition}</div>
              </div>
            </a>
          );
        })}
      </div>
    </CollapsibleSection>
  )}

  <SourcesBlock figureId={figureId} lang={lang} />

  <PublicCTA
    variant="sticky"
    figureId={figureId}
    figureName={shortName}
    lang={lang}
  />
</div>

<style is:global>
  .pub-figure__poems {
    margin: 0.5rem 0 2rem;
  }
  .pub-figure__poems-link {
    margin-top: 0.5rem;
    font-size: 1.05rem;
  }
  .pub-figure__qa {
    margin-top: 1.5rem;
  }
  .pub-figure__qa-q {
    font-family: var(--font-content, 'Libre Caslon Text', serif);
    font-size: 1.1rem;
    color: var(--gold-primary);
    margin: 0 0 0.4rem;
  }
  /* A2: the figure's essence as a visible lead paragraph below the hero. The
     only prominent, uncollapsed, on-topic body text on the page, which is what
     a "tell me about X" visitor came for and what AI engines extract. Double-
     scoped so it beats the base .pub-section__text spacing regardless of order. */
  .pub-figure .pub-fig-essence {
    margin: 0 0 1.75rem;
    font-size: 1.1rem;
    line-height: 1.75;
  }
  /* A1: each Idea is now title + a one-line summary gloss, with optional core
     ideas in a nested native <details>. Turns 12 bare titles into real,
     crawlable context, zero new prose (all from existing seed data). */
  .pub-ideas__title {
    font-weight: 600;
  }
  .pub-ideas__summary {
    display: block;
    margin-top: 0.2rem;
    font-size: 0.95rem;
    line-height: 1.55;
    opacity: 0.85;
  }
  .pub-ideas__insights {
    margin-top: 0.4rem;
    font-size: 0.92rem;
  }
  .pub-ideas__insights > summary {
    cursor: pointer;
    color: var(--gold-primary);
  }
  .pub-ideas__insights ul {
    margin: 0.4rem 0 0;
    padding-left: 1.1rem;
  }
  .pub-figure__hublink {
    margin: 0.75rem 0 1.5rem;
  }
  .pub-figure__methodlink {
    margin: 0.6rem 0 0;
    font-size: 0.95rem;
  }
  /* The inline figure CTA above is desktop-only (hidden on mobile, where the
     sticky bar carries the deep-link). The journey-path section above it has a
     3rem bottom margin and the inline variant adds 2rem 0 of its own padding,
     which stacked into a big empty band. Pull the CTA up tight under the
     "new here, start with the first story" nudge and trim its padding. The
     double class beats .pub-cta--inline regardless of bundle order. */
  .pub-cta--inline.pub-cta--desktop {
    margin-top: -2rem;
    padding: 0 0 1.5rem;
  }
  @media (max-width: 640px) {
    .pub-cta--desktop {
      display: none;
    }
  }
  /* Related-figures rows: horizontal card variant (was an inline style,
     moved to a class so the strict CSP style-src needs no 'unsafe-inline'). */
  .pub-figure-card.pub-figure-card--row {
    flex-direction: row;
    gap: 0.75rem;
    align-items: center;
    padding: 0.75rem;
  }
</style>
