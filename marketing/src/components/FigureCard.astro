---
import StaticImage from './StaticImage.astro';
import type { Lang } from '../i18n';
import { publicUrl } from '../lib/urls';
import { figureIdToSlug } from '@client/data/public/slugMap';
import type { PublicFigure } from '@client/data/public/figuresCatalog';

interface Props {
  figure: PublicFigure;
  lang: Lang;
  /** Heading level for the figure name. The /figures catalog pages keep the
   *  default h2; the homepage grid sits under its own h2 and passes h3. */
  headingLevel?: 'h2' | 'h3';
}

const { figure, lang, headingLevel = 'h2' } = Astro.props;
const Heading = headingLevel;
const slug = figureIdToSlug[figure.id] || figure.id;
const learnLine = figure.learn.trim();
const fallback = figure.about.split('\n')[0].slice(0, 110);
---
<a href={publicUrl(lang, `/figures/${slug}`)} class="pub-figure-card">
  <div class="pub-figure-card__image">
    <StaticImage figureId={figure.id} type="thumbnail" alt="" loading="lazy" />
  </div>
  <div class="pub-figure-card__body">
    <Heading class="pub-figure-card__name">{figure.name}</Heading>
    <p class="pub-figure-card__tradition">{figure.tradition}</p>
    {learnLine ? (
      <p class="pub-figure-card__learn">{learnLine}</p>
    ) : (
      <p class="pub-figure-card__about">{fallback}</p>
    )}
  </div>
</a>
