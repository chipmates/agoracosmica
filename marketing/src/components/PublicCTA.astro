---
// Sticky bottom CTA. Static HTML — the conversion fire + entry-intent capture
// happens in PublicScript.astro (vanilla JS event delegation on the
// data-agc-cta attribute). The label varies: figure pages say "Learn from
// Echo of {name}", theme pages with a featured council deep-link to that
// council, everything else "Start exploring".

import { getT } from '../i18n';
import type { Lang } from '../i18n';
import { figureIdToSlug } from '@client/data/public/slugMap';

interface Props {
  variant?: 'sticky' | 'inline';
  /** Figure-page CTA — adds figureId to the conversion metadata. */
  figureId?: string;
  figureName?: string;
  /** Theme-page CTA — deep-link into the featured council. */
  councilId?: string;
  /** Theme-page CTA without a featured council — generic council label. */
  councilCta?: boolean;
  lang: Lang;
  class?: string;
}

const {
  variant = 'sticky',
  figureId,
  figureName,
  councilId,
  councilCta,
  lang,
  class: className = '',
} = Astro.props;

const t = getT(lang);

const label = councilId
  ? t('cta.listenFeaturedDebate', 'Listen to the featured debate')
  : figureName
    ? t('cta.learnFrom').replace('{name}', figureName)
    : councilCta
      ? t('cta.enterCouncil', 'Enter the Cosmic Council')
      : t('cta.startFree');

// Deep-link the CTA so the figure/council survives a new-tab open, a shared
// link, or blocked JS (the data-agc-* attributes stay as the same-tab fast
// path; index.tsx reads ?figure=/?council= at boot). Use the public figure
// slug for a human-meaningful, SEO-aligned URL; councils use their id (the
// in-app consumer expects the id).
const figureSlug = figureId ? figureIdToSlug[figureId] : undefined;
const ctaHref = figureSlug
  ? `/app?figure=${figureSlug}`
  : councilId
    ? `/app?council=${councilId}`
    : '/app';
---
<div class={`pub-cta pub-cta--${variant} ${className}`}>
  <div class="pub-cta__inner">
    <p class="pub-cta__trust">{t('cta.trust')}</p>
    <a
      href={ctaHref}
      class="pub-cta__button"
      data-agc-cta="start-exploring"
      data-agc-figure={figureId}
      data-agc-council={councilId}
    >
      {label}
    </a>
  </div>
</div>
