---
// The hero block at the top of every figure detail page. The piece that
// must paint immediately for ad clickers — portrait, eyebrow, name, meta,
// learn line, trailer button (React island), about paragraphs. Pre-static
// markup, the only client-side bit is the trailer button.

import FigurePortrait from './FigurePortrait.astro';
import TrailerButton from '../islands/TrailerButton';
import { getT } from '../i18n';
import type { Lang } from '../i18n';
import { getPublicTrailerUrl } from '@client/utils/public/publicMediaUrl';

interface Figure {
  id: string;
  name: string;
  period?: string;
  tradition?: string;
  about: string;
  learn?: string;
}

interface Props {
  figure: Figure;
  lang: Lang;
}

const { figure, lang } = Astro.props;
const t = getT(lang);

const metaLine = [figure.tradition, figure.period].filter(Boolean).join('  ·  ');
// No-JS fallback: a plain link to the raw trailer mp3, same URL the island's
// audio hook builds, so the SSR'd play button is never a dead end.
const trailerMp3 = getPublicTrailerUrl(figure.id, lang, 'mp3');
const aboutParas = figure.about
  .split('\n')
  .map(p => p.trim())
  .filter(Boolean);
---
<section class="pub-fig-hero">
  <div class="pub-fig-hero__portrait">
    <FigurePortrait figureId={figure.id} alt={figure.name} />
  </div>
  <div class="pub-fig-hero__text">
    <p class="pub-fig-hero__eyebrow">{t('figures.echoOf')}</p>
    <h1 class="pub-fig-hero__name">{figure.name}</h1>
    <p class="pub-fig-hero__meta">{t('figures.echoGloss')}</p>
    {metaLine && <p class="pub-fig-hero__meta">{metaLine}</p>}
    {figure.learn && (
      <p class="pub-fig-hero__learn">{`“${figure.learn}”`}</p>
    )}
    <TrailerButton client:visible figureId={figure.id} lang={lang} />
    <noscript>
      <a class="pub-textlink" href={trailerMp3}>
        {lang === 'de' ? 'Intro anhören (MP3)' : 'Listen to the intro (MP3)'}
      </a>
    </noscript>
    {aboutParas.map(p => <p class="pub-fig-hero__about">{p}</p>)}
  </div>
</section>
