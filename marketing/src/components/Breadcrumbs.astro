---
// Breadcrumb navigation (visible markup only). The BreadcrumbList JSON-LD is
// emitted by each page template via the `schemas` prop, so this component must
// NOT emit its own: doing so produced a second, conflicting BreadcrumbList on
// every figure/theme/catalog page (the template's was correct and complete;
// this one dropped the leaf and pointed Home at /figures).

import { getT } from '../i18n';
import type { Lang } from '../i18n';
import { publicUrl } from '../lib/urls';

export interface BreadcrumbItem {
  label: string;
  /** Omit for the current page (last item). */
  path?: string;
}

interface Props {
  items: BreadcrumbItem[];
  lang: Lang;
}

const { items, lang } = Astro.props;
const t = getT(lang);

const allItems: BreadcrumbItem[] = [
  { label: t('breadcrumbs.home'), path: '/' },
  ...items,
];
---
<nav aria-label="Breadcrumb" class="pub-breadcrumbs">
  <ol>
    {allItems.map((item, i) => (
      <li>
        {i > 0 && <span class="pub-breadcrumbs__sep" aria-hidden="true">/</span>}
        {item.path ? (
          <a href={publicUrl(lang, item.path)}>{item.label}</a>
        ) : (
          <span aria-current="page">{item.label}</span>
        )}
      </li>
    ))}
  </ol>
</nav>
