---
import '../../styles/legal.css';

interface Props {
  title: string;
  lastUpdated: string;
  lang?: 'de' | 'en';
}

const { title, lastUpdated, lang = 'de' } = Astro.props;
const isEn = lang === 'en';
---
<article class="legal-doc">
  <header class="legal-doc__header">
    <h1 class="legal-doc__title">{title}</h1>
    <p class="legal-doc__date">{lastUpdated}</p>
  </header>

  <slot />

  <div class="legal-doc__footer">
    <nav class="legal-doc__footer-links" aria-label={isEn ? 'Legal' : 'Rechtliches'}>
      <a href="/impressum/">{isEn ? 'Imprint' : 'Impressum'}</a>
      <span class="legal-doc__footer-sep">•</span>
      <a href={isEn ? '/privacy' : '/datenschutz/'}>{isEn ? 'Privacy Policy' : 'Datenschutzerklärung'}</a>
      <span class="legal-doc__footer-sep">•</span>
      <a href="/cookie-policy/">{isEn ? 'Cookie Policy' : 'Cookie-Richtlinie'}</a>
      <span class="legal-doc__footer-sep">•</span>
      <a href="/nutzungsbedingungen/">{isEn ? 'Terms' : 'Nutzungsbedingungen'}</a>
    </nav>
  </div>
</article>
