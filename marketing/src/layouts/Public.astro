---
// Root layout for every public marketing page. Wraps the page slot in the
// navbar/footer chrome, drops in <BaseHead /> with all the meta + JSON-LD,
// and pulls in the existing public CSS files so visuals stay identical to
// the React rendering of the same pages.

import BaseHead from '../components/BaseHead.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import PublicScript from '../components/PublicScript.astro';
import AdConsentPrompt from '../islands/AdConsentPrompt';
import { getT } from '../i18n';
import type { Lang } from '../i18n';

import '@client/index.css';
import '@client/styles/public/public-layout.css';
import '@client/styles/public/public-pages.css';
import '@client/styles/public/public-cards.css';

interface Props {
  title: string;
  fullTitle?: string;
  description: string;
  canonicalPath: string;
  lang: Lang;
  ogType?: 'website' | 'article' | 'profile';
  ogImage?: string;
  ogImageAlt?: string;
  preloadImage?: string;
  preloadImageSrcset?: string;
  preloadImageSizes?: string;
  preloadImageType?: string;
  schemas?: Array<Record<string, unknown>>;
  includeRss?: boolean;
  noHreflang?: boolean;
  /** Internal lab/preview pages: emit robots noindex. */
  noindex?: boolean;
  /** Set false on pages that render their own dedicated CTA (figure + theme detail). */
  stickyCta?: boolean;
}

const props = Astro.props;
const currentPath = Astro.url.pathname;
const t = getT(props.lang);
// The homepage hero already shows a Start Exploring CTA, so the mobile sticky
// bar starts hidden there and only slides in once the hero scrolls away (see
// .pub-cta--sticky in public-layout.css + the reveal logic in agc-public.js).
// Other pages have no hero and keep the bar visible from first paint.
const isHome = currentPath === '/' || currentPath === '/de/' || currentPath === '/de';
---
<!doctype html>
<html lang={props.lang}>
  <head>
    <BaseHead {...props} />
  </head>
  <body class={isHome ? 'pub-home-page' : undefined}>
    <a href="#main-content" class="pub-skip-link">
      {props.lang === 'de' ? 'Zum Inhalt springen' : 'Skip to content'}
    </a>
    <div class="public-page">
      <Navbar lang={props.lang} currentPath={currentPath} />
      <main class="pub-main" id="main-content">
        <slot />
      </main>
      <Footer lang={props.lang} />
    </div>
    <!-- Mobile-only sticky CTA. On mobile the navbar CTA sits inside the
         hamburger, so this keeps a visible app entry at the bottom. Hidden on
         desktop, where the navbar CTA is always shown. Suppressed on pages that
         render their own dedicated CTA (figure + theme detail). -->
    {props.stickyCta !== false && (
      <div class="pub-cta pub-cta--sticky">
        <div class="pub-cta__inner">
          <a href="/app" class="pub-cta__button" data-agc-cta="start-exploring">{t('nav.startExploring')}</a>
        </div>
      </div>
    )}
    <PublicScript />
    {/* Ad-measurement consent prompt, shown only to Google ad-grant arrivals
        (a gclid in the URL, not the paid ?p=1 split). Non-blocking, decides
        client-side, renders nothing for everyone else. */}
    <AdConsentPrompt client:idle lang={props.lang} />
  </body>
</html>

<style is:global>
  /* Keyboard skip link: visually hidden until it receives keyboard focus,
     then slides in above the sticky navbar (navbar z-index is 100). */
  .pub-skip-link {
    position: absolute;
    top: 0;
    left: 0;
    z-index: 200;
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    padding: 0.75rem 1.25rem;
    background: var(--bg-card);
    color: var(--gold-primary);
    font-family: var(--font-ui, 'Space Grotesk', sans-serif);
    text-decoration: underline;
    transform: translateY(-150%);
  }
  .pub-skip-link:focus-visible {
    transform: translateY(0);
  }
</style>
