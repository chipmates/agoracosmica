---
import Public from '../layouts/Public.astro';
import AboutContent from '../components/AboutContent.astro';
import { getT } from '../i18n';
import {
  agoraCosmicaSchema,
  organizationSchema,
  webSiteSchema,
  softwareApplicationSchema,
  podcastSeriesSchema,
  breadcrumbSchema,
} from '../lib/schemas';
import { SITE_URL } from '../lib/urls';

const lang = 'en' as const;
const t = getT(lang);
---
<Public
  title={t('about.pageTitle')}
  description={t('about.pageDescription')}
  canonicalPath="/about"
  lang={lang}
  ogType="website"
  includeRss={true}
  schemas={[
    agoraCosmicaSchema(),
    organizationSchema(),
    webSiteSchema(),
    softwareApplicationSchema(),
    podcastSeriesSchema(lang),
    breadcrumbSchema([
      { name: t('breadcrumbs.home'), url: `${SITE_URL}/` },
      { name: t('breadcrumbs.about'), url: `${SITE_URL}/about` },
    ]),
  ]}
>
  <AboutContent lang={lang} />
</Public>
