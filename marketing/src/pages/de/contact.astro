---
import Public from '../../layouts/Public.astro';
import ContactContent from '../../components/ContactContent.astro';
import { getT } from '../../i18n';
import { organizationSchema, breadcrumbSchema } from '../../lib/schemas';
import { SITE_URL } from '../../lib/urls';

const lang = 'de' as const;
const t = getT(lang);

const contactSchema = {
  ...organizationSchema(),
  contactPoint: {
    '@type': 'ContactPoint',
    email: 'agoracosmica@chipmates.ai',
    contactType: 'customer service',
    availableLanguage: ['English', 'German'],
  },
};
---
<Public
  title={t('contact.pageTitle')}
  description={t('contact.pageDescription')}
  canonicalPath="/contact"
  lang={lang}
  schemas={[
    contactSchema,
    breadcrumbSchema([
      { name: t('breadcrumbs.home'), url: `${SITE_URL}/de/` },
      { name: t('breadcrumbs.contact'), url: `${SITE_URL}/de/contact` },
    ]),
  ]}
>
  <ContactContent lang={lang} />
</Public>
