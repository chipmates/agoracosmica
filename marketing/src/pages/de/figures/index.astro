---
import Public from '../../../layouts/Public.astro';
import FigureOrbit from '../../../components/landing-lab/FigureOrbit.astro';
import V2ObservatoryMotion from '../../../islands/V2ObservatoryMotion';
import FiguresCatalogContent from '../../../components/FiguresCatalogContent.astro';
import { getT } from '../../../i18n';
import { itemListSchema, breadcrumbSchema } from '../../../lib/schemas';
import { canonicalUrl, publicUrl, SITE_URL, MEDIA_URL } from '../../../lib/urls';
import { getFiguresCatalog } from '@client/data/public/figuresCatalog';
import { figureIdToSlug } from '@client/data/public/slugMap';

const lang = 'de' as const;
const t = getT(lang);

const figures = getFiguresCatalog(lang);

const figureItems = figures.map(f => ({
  name: f.name,
  url: canonicalUrl(publicUrl(lang, `/figures/${figureIdToSlug[f.id]}`)),
  description: f.about.split('\n')[0].slice(0, 160),
  image: `${MEDIA_URL}/images/figures/${f.id}/main/1200.webp`,
}));

const schemas = [
  itemListSchema(figureItems),
  breadcrumbSchema([
    { name: t('breadcrumbs.home'), url: `${SITE_URL}/de/` },
    { name: t('breadcrumbs.figures'), url: `${SITE_URL}/de/figures` },
  ]),
];

// The orbit's first planet (Mark Aurel) is the LCP. Preload it to match the
// img FigureOrbit marks fetchpriority=high (src/srcset/sizes must match).
const lcpPortrait = `${MEDIA_URL}/images/figures/aurelius/thumbnail/320.webp`;
const lcpPortraitSrcset = `${MEDIA_URL}/images/figures/aurelius/thumbnail/160.webp 160w, ${MEDIA_URL}/images/figures/aurelius/thumbnail/320.webp 320w`;
const lcpPortraitSizes = '(max-width: 900px) 56px, 88px';
---
<Public
  title="30 bemerkenswerte Menschen"
  description={t('figures.pageDescription')}
  canonicalPath="/figures"
  lang={lang}
  schemas={schemas}
  heroReveal={true}
  preloadImage={lcpPortrait}
  preloadImageSrcset={lcpPortraitSrcset}
  preloadImageSizes={lcpPortraitSizes}
  preloadImageType="image/webp"
>
  <FigureOrbit lang={lang} />
  <V2ObservatoryMotion client:idle targetId="figures-orbit" />
  <FiguresCatalogContent lang={lang} gridOnly={true} />
</Public>
