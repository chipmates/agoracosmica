---
import Public from '../../../layouts/Public.astro';
import ThemeDetailContent from '../../../components/ThemeDetailContent.astro';

import { getT } from '../../../i18n';
import { articleSchema, breadcrumbSchema, faqSchema } from '../../../lib/schemas';
import { canonicalUrl, publicUrl, SITE_URL, MEDIA_URL } from '../../../lib/urls';
import { themeContentLastmod } from '../../../lib/lastmod';
import { THEMES, type ThemeId } from '@client/data/councilCatalog';

const THEME_OG_FIGURE: Record<string, string> = {
  'meaning-purpose': 'aurelius',
  'loss-grief': 'mandela',
  'who-am-i': 'kahlo',
  'mind-creativity': 'einstein',
  'love-connection': 'rumi',
  'freedom-justice': 'king',
  'faith-death-mystery': 'bingen',
  'moral-life': 'gandhi',
};

const LAUNCH_DATE = '2026-05-06';

export async function getStaticPaths() {
  return THEMES.map(theme => ({
    params: { theme: theme.id },
    props: { themeId: theme.id as ThemeId },
  }));
}

const lang = 'de' as const;
const { themeId } = Astro.props as { themeId: ThemeId };

const t = getT(lang);
const themeName = t(`themes.${themeId}.name`);
const themeDescription = t(`themes.${themeId}.description`);
const themeQuestion = t(`themes.${themeId}.question`);
const themeAnswer = t(`themes.${themeId}.answer`);
const hasQa =
  themeQuestion !== `themes.${themeId}.question` && themeAnswer !== `themes.${themeId}.answer`;

const ogFigureId = THEME_OG_FIGURE[themeId];
const themeOgImage = ogFigureId
  ? `${MEDIA_URL}/images/figures/${ogFigureId}/main/1200.webp`
  : undefined;
const themeUrl = canonicalUrl(publicUrl(lang, `/themes/${themeId}`));

const schemas = [
  articleSchema({
    title: themeName,
    // Full text on purpose: JSON-LD has no SERP length budget, and a raw
    // .slice() cuts mid-word (the meta description below is word-boundary
    // clamped centrally in BaseHead).
    description: themeDescription,
    url: themeUrl,
    lang,
    image: themeOgImage,
    datePublished: LAUNCH_DATE,
    dateModified: themeContentLastmod(),
  }),
  breadcrumbSchema([
    { name: t('breadcrumbs.home'), url: `${SITE_URL}/de/` },
    { name: t('breadcrumbs.themes'), url: `${SITE_URL}/de/themes` },
    { name: themeName, url: themeUrl },
  ]),
  ...(hasQa ? [faqSchema([{ q: themeQuestion, a: themeAnswer }], themeUrl)] : []),
];
---
<Public
  title={hasQa ? themeQuestion : themeName}
  description={themeDescription}
  canonicalPath={`/themes/${themeId}`}
  lang={lang}
  stickyCta={false}
  ogType="article"
  ogImage={themeOgImage}
  ogImageAlt={themeName}
  schemas={schemas}
>
  <ThemeDetailContent themeId={themeId} lang={lang} />
</Public>
