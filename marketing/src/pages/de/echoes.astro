---
// Stufe 3 der Echo-Offenlegung: die stabile, teilbare URL für die Frage
// „Ist das nicht respektlos?“ (FAQ Stufe 1 + Ausklapp-Stufe 2 liegen auf der
// Startseite). Im Repo gespiegelt als docs/WHY-ECHOES.md.
import Public from '../../layouts/Public.astro';
import EchoesContent from '../../components/EchoesContent.astro';
import { organizationSchema, breadcrumbSchema, articleSchema } from '../../lib/schemas';
import { getT } from '../../i18n';
import { SITE_URL, MEDIA_URL } from '../../lib/urls';

const lang = 'de' as const;
const t = getT(lang);
const echoesUrl = `${SITE_URL}/de/echoes/`;
const description = 'Jede Persönlichkeit ist ein KI-Echo eines Menschen, der nicht zustimmen kann. Warum wir dieses Wort gewählt haben, was die Tradition zeigt und wo die Risiken liegen.';
---
<Public
  title="Warum eigentlich Echos?"
  description={description}
  canonicalPath="/echoes"
  lang={lang}
  ogType="article"
  schemas={[
    organizationSchema(),
    articleSchema({
      title: 'Warum eigentlich Echos?',
      description,
      url: echoesUrl,
      lang,
      image: `${MEDIA_URL}/images/ui/og-default/1200.webp`,
      datePublished: '2026-06-10',
      dateModified: '2026-06-11',
    }),
    breadcrumbSchema([
      { name: t('breadcrumbs.home'), url: `${SITE_URL}/de/` },
      { name: 'Warum eigentlich Echos?', url: echoesUrl },
    ]),
  ]}
>
  <EchoesContent lang={lang} />
</Public>
