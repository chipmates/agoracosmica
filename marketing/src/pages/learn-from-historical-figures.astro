---
// The broadest LEARN hub (EN). The true parent of the 8 theme pages: learn
// timeless wisdom from 30 figures of history. The DE twin lives at
// /de/von-historischen-persoenlichkeiten-lernen. The route is thin: resolve
// lang, build the schemas array, render <Public><WisdomHubContent /></Public>.
// The FAQ array is defined once in the content component and passed to BOTH the
// visible render and faqSchema(), so the JSON-LD can never drift from the DOM.
// Title / H1 / meta use only this page's head-term cluster (wisdom app /
// timeless wisdom / learn from historical figures), never another hub's terms.
import Public from '../layouts/Public.astro';
import WisdomHubContent from '../components/WisdomHubContent.astro';
import { getWisdomFaq, HUB_THEME_IDS } from '../lib/wisdomHubData';
import {
  organizationSchema,
  agoraCosmicaSchema,
  softwareApplicationSchema,
  faqSchema,
  breadcrumbSchema,
  itemListSchema,
} from '../lib/schemas';
import { getT } from '../i18n';
import { canonicalUrl, publicUrl, SITE_URL } from '../lib/urls';
import { getFiguresCatalog } from '@client/data/public/figuresCatalog';
import { figureIdToSlug } from '@client/data/public/slugMap';

const lang = 'en' as const;
const t = getT(lang);

const figures = getFiguresCatalog(lang);
const faq = getWisdomFaq(lang);

const canonical = canonicalUrl(publicUrl(lang, '/learn-from-historical-figures'));

const themeListItems = HUB_THEME_IDS.map(id => ({
  name: t(`themes.${id}.name`),
  url: canonicalUrl(publicUrl(lang, `/themes/${id}`)),
  description: t(`themes.${id}.tagline`),
}));
const figureListItems = figures.map(f => ({
  name: f.name,
  url: canonicalUrl(publicUrl(lang, `/figures/${figureIdToSlug[f.id] || f.id}`)),
  description: f.learn.trim(),
}));

const schemas = [
  organizationSchema(),
  agoraCosmicaSchema(),
  softwareApplicationSchema(),
  faqSchema(faq, canonical),
  breadcrumbSchema([
    { name: t('breadcrumbs.home'), url: `${SITE_URL}/` },
    { name: 'Learn from historical figures', url: canonical },
  ]),
  itemListSchema([...themeListItems, ...figureListItems]),
];
---
<Public
  title="Wisdom App"
  fullTitle="Learn Timeless Wisdom From 30 Figures of History"
  description="A nonprofit wisdom learning platform. Learn ancient and timeless wisdom from 30 historical figures across philosophy, science, art, and faith. No tracking cookies."
  canonicalPath="/learn-from-historical-figures"
  lang={lang}
  ogType="website"
  schemas={schemas}
  altEn="/learn-from-historical-figures"
  altDe="/de/von-historischen-persoenlichkeiten-lernen"
>
  <WisdomHubContent lang={lang} faq={faq} figures={figures} />
</Public>
