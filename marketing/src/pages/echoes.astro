---
// Tier 3 of the Echo disclosure: the stable, shareable URL for the
// "isn't this disrespectful" question (FAQ Tier 1 + unfold Tier 2 live on
// the homepage). Mirrored in the repo as docs/WHY-ECHOES.md.
import Public from '../layouts/Public.astro';
import EchoesContent from '../components/EchoesContent.astro';
import { organizationSchema, breadcrumbSchema, articleSchema } from '../lib/schemas';
import { getT } from '../i18n';
import { SITE_URL, MEDIA_URL } from '../lib/urls';

const lang = 'en' as const;
const t = getT(lang);
const echoesUrl = `${SITE_URL}/echoes/`;
const description = 'Every figure here is an AI Echo of a real person who cannot consent. Why we chose that word, what the tradition shows, and where the risks lie.';
---
<Public
  title="Why We Call Them Echoes"
  description={description}
  canonicalPath="/echoes"
  lang={lang}
  ogType="article"
  schemas={[
    organizationSchema(),
    articleSchema({
      title: 'Why We Call Them Echoes',
      description,
      url: echoesUrl,
      lang,
      image: `${MEDIA_URL}/images/ui/og-default/1200.webp`,
      datePublished: '2026-06-10',
      dateModified: '2026-06-11',
    }),
    breadcrumbSchema([
      { name: t('breadcrumbs.home'), url: `${SITE_URL}/` },
      { name: 'Why we call them Echoes', url: echoesUrl },
    ]),
  ]}
>
  <EchoesContent lang={lang} />
</Public>
