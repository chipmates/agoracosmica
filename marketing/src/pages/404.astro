---
import Public from '../layouts/Public.astro';

// Real 404 page. CF Pages serves this with HTTP status 404 for any path that
// matches neither a static file nor a _redirects rule, replacing the old
// catch-all that answered every junk URL with a 200 SPA shell whose canonical
// pointed at the homepage (a classic soft-404).
const lang = 'en' as const;
---
<Public
  title="Page not found"
  description="This page does not exist. The library is still open."
  canonicalPath="/404"
  lang={lang}
  noHreflang
  stickyCta={false}
>
  <section class="not-found">
    <p class="not-found__code">404</p>
    <h1>This page does not exist</h1>
    <p class="not-found__lede">
      Maybe a link went stale or a letter slipped. The library is still open.
    </p>
    <p class="not-found__links">
      <a href="/">Go to the homepage</a>
      <a href="/figures/">Browse the figures</a>
      <a href="/themes/">Explore the themes</a>
    </p>
    <p class="not-found__de" lang="de">
      Diese Seite gibt es nicht. <a href="/de/">Zur deutschen Startseite</a>.
    </p>
  </section>
</Public>

<style>
  .not-found {
    max-width: 42rem;
    margin: 0 auto;
    padding: 6rem 1.5rem;
    text-align: center;
  }
  .not-found__code {
    font-size: 0.9rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.7;
  }
  .not-found h1 {
    margin: 0.5rem 0 1rem;
  }
  .not-found__lede {
    margin-bottom: 2rem;
  }
  .not-found__links {
    display: flex;
    gap: 1.25rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .not-found__de {
    margin-top: 2.5rem;
    font-size: 0.95rem;
    opacity: 0.8;
  }
</style>
