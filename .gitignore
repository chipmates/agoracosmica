# ─────────────────────────────────────────────────────────────
#  Agora Cosmica
#  Conventions: lowercase paths; one rule per line; sectioned;
#  negations only where strictly needed.
# ─────────────────────────────────────────────────────────────

# ── OS & editor ────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
*.swp
*.swo
**/.claude/settings.local.json

# ── Dependencies ───────────────────────────────────────────
node_modules/
.pnpm-store/

# ── Build output ───────────────────────────────────────────
dist/
build/
out/
.vite/
.astro/
*.tsbuildinfo

# ── Test artifacts ─────────────────────────────────────────
coverage/
.nyc_output/
playwright-report/
test-results/
*.test.log

# ── Logs & runtime ─────────────────────────────────────────
*.log
logs/
*.pid
*.pid.lock

# ── Cache ──────────────────────────────────────────────────
.cache/
.eslintcache
.stylelintcache
.turbo/

# ── Python runtime artifacts ───────────────────────────────
**/__pycache__/
*.pyc

# ── Cloudflare Wrangler ────────────────────────────────────
.wrangler/

# ── Environment & secrets ──────────────────────────────────
.env
.env.*
!.env.example
!.env.*.example
.dev.vars
*.pem
*.key
secrets/

# ── Local-only media (served from R2 in production) ────────
# Pull with: pnpm setup:assets
# Note: use /* (glob) not / (directory) where negations are needed below,
# so git can traverse into the directory and re-include specific files.
client/src/assets/audio/
client/src/assets/stories/*
client/src/assets/councils/*
client/src/assets/prisms/*
client/src/assets/initial-messages/
client/src/assets/figures/originals/
client/src/assets/figures/full/
client/src/assets/figures/thumbnails/
client/src/assets/backgrounds/originals/
client/src/assets/backgrounds/processed/
client/src/assets/icons/originals/
client/src/assets/icons/processed/
client/src/assets/ui/originals/
client/src/assets/ui/processed/
client/src/assets/music*.webm
client/public/assets/

# ── Keep manifest stubs even when parent is ignored ────────
!**/.gitkeep
!client/src/assets/councils/councilCatalog.json

# ── Landing-lab design experiments (local only) ────────────
# The First Exchange hero and the figure orbit were chosen and promoted into
# the real pages (now tracked). The rejected hero variants, the interactive
# library experiments, and the lab preview pages stay out of version control.
# The lab preview pages moved to .lab-pages-archive/ so they no longer build
# into production (they carry inline styles the CSP blocks); restore into
# src/pages/lab/ locally to preview a variant.
marketing/.lab-pages-archive/
marketing/src/components/landing-lab/HeroListening.astro
marketing/src/components/landing-lab/hero-listening.css
marketing/src/islands/VoiceDeck.tsx
# (The interactive library module was promoted to the homepage: LabLibrary.tsx,
# LabSamplePlayer.tsx, lab-library.ts, lab-library.css, lab-samples.css are now
# tracked. lab-samples.ts stays local — only the archived lab pages use it.)
marketing/src/components/landing-lab/HeroAskListen.astro
marketing/src/components/landing-lab/HeroStory.astro
marketing/src/components/landing-lab/LabWhatIs.astro
marketing/src/components/landing-lab/LabLibraryBento.astro
marketing/src/components/landing-lab/LabLibraryScroll.astro
marketing/src/components/landing-lab/LabModeSample.astro
marketing/src/components/landing-lab/LabStoryFeature.astro
marketing/src/components/landing-lab/lab-samples.ts
