# Vite Environment Variables
VITE_ENV=development

# Multilingual structure toggle
VITE_USE_MULTILINGUAL_STRUCTURE=false

# Storage provider toggle (R2 vs B2)
VITE_USE_R2=true

# Feature flags (string 'true' to enable)
VITE_FF_SESSION_ZUSTAND=false
VITE_FF_CONVERSATION_ZUSTAND=false
VITE_FF_COUNCIL_ZUSTAND=false
VITE_FF_UI_ZUSTAND=false
VITE_FF_IDB_STORAGE=false

# BYOK (Bring Your Own Key) feature
VITE_BYOK_ENABLED=true

# Self-hosted audio API (GEX130)
# Default: https://audio.agoracosmica.org (CF Worker — preferred path)
# VITE_AUDIO_API_URL=https://audio.agoracosmica.org
# VITE_AUDIO_API_KEY=your-gateway-bearer-token

# Operator-only: admin bypass token for direct-to-origin scripts.
# Used by maintenance scripts that need to hit fsn1/nbg1 directly without
# going through the Worker (e.g. voice rendering, load tests). nginx accepts
# it as `X-Admin-Token` from any IP, in lieu of the Worker's X-Origin-Verify.
# Generate with: openssl rand -hex 32 — keep in 1Password, never commit.
# Self-hosters don't need this unless they replicate our two-token scheme.
# AUDIO_ADMIN_TOKEN=your-admin-bypass-token

# ============================================
# Developer API Keys (Local Development Only)
# ============================================
# These keys are YOUR personal keys for testing during development.
# They will be auto-populated in the API Keys settings panel when you
# clear browser cache, saving you from re-entering them each time.
#
# IMPORTANT: Copy this file to .env and add your actual keys.
# The .env file is gitignored and will never be committed.

# OpenRouter Key (for AI conversations)
# Get yours at: https://openrouter.ai/settings/keys
VITE_DEV_OPENROUTER_KEY=your-openrouter-key-here

# OpenAI Key (for voice features: TTS/STT)
# Get yours at: https://platform.openai.com/api-keys
VITE_DEV_OPENAI_KEY=your-openai-key-here