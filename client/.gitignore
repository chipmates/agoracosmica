# Audio assets (large; never tracked, served from R2 in production)
# Note: use /* (glob) not / (directory) so negations below can reach inside.
src/assets/stories/*
src/assets/councils/*
src/assets/prisms/*

# Keep directory structure and catalog data
!src/assets/stories/.gitkeep
!src/assets/councils/.gitkeep
!src/assets/councils/councilCatalog.json
!src/assets/prisms/.gitkeep

# Curated content — fetched at setup time from production CDN.
# Per CONTENT-LICENSE.md, content is © ChipMates pending CC-BY 4.0 transition.
# Pull all of this with: pnpm setup:assets
src/assets/translations/seeds/*
src/assets/translations/figures/*
src/assets/factchecks/*
src/assets/voice_profiles/*
src/assets/instructions/*

# Build-time data extraction — auto-generated by scripts/extract-public-data.mjs
# from the curated content above. Regenerated on every `pnpm build`.
# figureSeo.ts and slugMap.ts are hand-maintained and NOT generated, so they
# stay tracked.
src/data/public/seeds/
src/data/public/stories/
src/data/public/themeSeedCrossRef.ts
src/data/public/figuresCatalog.ts
