# Trailing-slash canonicalization for static Astro pages.
# Astro emits /<path>/index.html and the sitemap lists the with-slash form.
# CF Pages serves matching static files BEFORE consulting these rules, so
# /themes/who-am-i/ still hits the Astro index.html unaffected. Without
# explicit 301s, the no-slash form (e.g. /themes/who-am-i) resolved via the
# SPA fallback below and rendered identical React content, creating
# duplicate-content entries in Google's index alongside the canonical URL.

# Per-slug Astro pages (EN + DE)
/figures/:slug    /figures/:slug/    301
/themes/:slug     /themes/:slug/     301
/de/figures/:slug /de/figures/:slug/ 301
/de/themes/:slug  /de/themes/:slug/  301

# Top-level Astro pages (EN + DE)
/figures   /figures/   301
/themes    /themes/    301
/about     /about/     301
/contact   /contact/   301
/impressum           /impressum/           301
/datenschutz         /datenschutz/         301
/cookie-policy       /cookie-policy/       301
/nutzungsbedingungen /nutzungsbedingungen/ 301
/de        /de/        301
/de/figures /de/figures/ 301
/de/themes  /de/themes/ 301
/de/about   /de/about/  301
/de/contact /de/contact/ 301

# App SPA — the React app (login + in-app surface) now lives under /app.
# CF Pages serves build/app/index.html for /app and any sub-path so React
# Router (basename "/app") handles client-side routing. /app is served bare
# (no trailing-slash 301) so it matches the manifest start_url, canonical,
# og:url, and the marketing CTA hrefs. These rules MUST precede the catch-all.
/app    /app/index.html  200
/app/*  /app/index.html  200

# SPA fallback — serve the React shell for all unmatched client-side routes.
# CF Pages serves existing static files first (JS, CSS, images, fonts) and the
# static Astro pages (build/index.html, /figures/, /themes/, etc.) before
# consulting these rules. Unknown paths reach the SPA router at /app, NOT the
# static homepage.
/* /app/index.html 200
