# Production Environment Configuration Example
# Copy to .env.production and customize for your deployment.

# ============================================================
# Media base URL
# ============================================================
# Where curated content (stories, councils, prisms) is served from.
# All audio + manifests live behind this base URL.

# Default: Cloudflare R2 via the audio-proxy Worker (production reference)
VITE_MEDIA_BASE_URL=https://media.agoracosmica.org

# Self-hosted, same-domain (serve /media from the web origin)
# VITE_MEDIA_BASE_URL=/media

# Local development server
# VITE_MEDIA_BASE_URL=http://localhost:8000

# See docs/SELF-HOSTING.md for end-to-end production setup.

# ============================================================
# Deployment mode
# ============================================================
# "true" builds the Docker self-host edition: BYOK-only, no free tier,
# no usage beacons, no Turnstile. The provided Dockerfile sets this for
# you. Leave unset for the hosted build.
# VITE_SELF_HOST=true
